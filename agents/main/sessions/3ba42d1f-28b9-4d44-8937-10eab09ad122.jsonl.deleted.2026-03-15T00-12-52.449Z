\"\n          ]\n        },\n        \"identity\": {\n          \"name\": \"CEO\",\n          \"theme\": \"executive leader\",\n          \"emoji\": \"👔\",\n          \"avatar\": \"avatar/CEO.png\"\n        },\n        \"groupChat\": {\n          \"mentionPatterns\": [\n            \"@openclaw\",\n            \"@助手\"\n          ]\n        },\n        \"subagents\": {\n          \"allowAgents\": [\n            \"*\"\n          ]\n        },\n        \"tools\": {\n          \"profile\": \"coding\",\n          \"allow\": [\n            \"browser\",\n            \"read\",\n            \"write\",\n            \"edit\",\n            \"exec\",\n            \"process\",\n            \"sessions_list\",\n            \"sessions_history\",\n            \"sessions_send\",\n            \"sessions_spawn\",\n            \"session_status\",\n            \"subagents\",\n            \"image\",\n            \"canvas\",\n            \"memory_search\",\n            \"memory_get\",\n            \"web_fetch\",\n            \"message\"\n          ],\n          \"deny\": [\n            \"nodes.camera.snap\",\n            \"nodes.screen.record\",\n            \"bash\",\n            \"nodes.camera.stream\",\n            \"nodes.mic.record\",\n            \"nodes.speaker.play\"\n          ]\n        }\n      }\n    ]\n  },\n  \"tools\": {\n    \"profile\": \"coding\",\n    \"allow\": [\n      \"browser\",\n      \"read\",\n      \"write\",\n      \"edit\",\n      \"exec\",\n      \"process\",\n      \"sessions_list\",\n      \"sessions_history\",\n      \"sessions_send\",\n      \"sessions_spawn\",\n      \"session_status\",\n      \"subagents\",\n      \"cron\",\n      \"gateway\",\n      \"image\",\n      \"canvas\",\n      \"memory_search\",\n      \"memory_get\",\n      \"web_search\",\n      \"web_fetch\",\n      \"message\"\n    ],\n    \"deny\": [\n      \"nodes.camera.snap\",\n      \"nodes.screen.record\",\n      \"bash\",\n      \"nodes.camera.stream\",\n      \"nodes.mic.record\",\n 
{"type":"message","id":"bd036eca","parentId":"538ba860","timestamp":"2026-03-11T15:37:16.104Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户要求生成一个真正终极的、包含所有 800+ 字段的完整配置模板。我需要将之前分散的文档整合成一个完整的、包含所有 34 个配置模块的终极模板。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_081aee2690294ae4ad8e4ff6","name":"write","arguments":{"path":"C:\\Users\\28964\\.openclaw\\workspace\\OpenClaw-终极配置模板-完整版.json5","content":"{\n  // ═══════════════════════════════════════════════════════════════\n  // OpenClaw 终极配置模板 - 完整版 (800+ 字段)\n  // ═══════════════════════════════════════════════════════════════\n  // 版本：2026.3.8\n  // 更新时间：2026-03-11\n  // 包含：34 个配置模块，800+ 配置字段\n  // 格式：JSON5 (支持注释和尾随逗号)\n  // 位置：~/.openclaw/openclaw.json\n  // ═══════════════════════════════════════════════════════════════\n\n  // ═══════════════════════════════════════════════════════════════\n  // 1. 元数据 (系统自动管理)\n  // ═══════════════════════════════════════════════════════════════\n  \"meta\": {\n    // 最后修改的 OpenClaw 版本号\n    \"lastTouchedVersion\": \"2026.3.8\",\n    // 最后修改时间 (ISO 8601, UTC)\n    \"lastTouchedAt\": \"2026-03-11T15:00:00.000Z\"\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 2. 向导记录 (自动写入)\n  // ═══════════════════════════════════════════════════════════════\n  \"wizard\": {\n    // 向导最后运行时间\n    \"lastRunAt\": \"2026-03-10T15:27:22.144Z\",\n    // 运行时的版本\n    \"lastRunVersion\": \"2026.3.8\",\n    // 运行的命令 (onboard | configure | channels | skills | etc)\n    \"lastRunCommand\": \"onboard\",\n    // 运行模式 (local | remote)\n    \"lastRunMode\": \"local\"\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 3. 环境变量配置\n  // ═══════════════════════════════════════════════════════════════\n  \"env\": {\n    // 从登录 shell 导入环境变量\n    \"shellEnv\": {\n      \"enabled\": false,\n      \"timeoutMs\": 15000\n    },\n    // 直接设置环境变量\n    \"vars\": {\n      // 示例：API Keys\n      // \"DASHSCOPE_API_KEY\": \"sk-...\",\n      // \"DASHSCOPE_CODING_API_KEY\": \"sk-...\",\n      // \"ANTHROPIC_API_KEY\": \"sk-ant-...\",\n      // \"OPENAI_API_KEY\": \"sk-...\",\n      // \"BRAVE_API_KEY\": \"...\",\n      // \"ELEVENLABS_API_KEY\": \"...\",\n      // \"TELEGRAM_BOT_TOKEN\": \"...\",\n      // \"DISCORD_BOT_TOKEN\": \"...\",\n      // \"SLACK_BOT_TOKEN\": \"xoxb-...\",\n      // \"SLACK_APP_TOKEN\": \"xapp-...\",\n      // \"OPENCLAW_GATEWAY_TOKEN\": \"...\"\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 4. 模型配置 - 核心模块\n  // ═══════════════════════════════════════════════════════════════\n  \"models\": {\n    \"providers\": {\n      // ────────────────────────────────────────────────────────────\n      // 阿里云百炼 - 通用模型\n      // ────────────────────────────────────────────────────────────\n      \"dashscope\": {\n        \"baseUrl\": \"https://dashscope.aliyuncs.com/compatible-mode/v1\",\n        \"apiKey\": \"${DASHSCOPE_API_KEY}\",\n        \"api\": \"openai-completions\",\n        \"models\": [\n          {\n            \"id\": \"qwen-plus\",\n            \"name\": \"Qwen Plus (PayGo)\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\"],\n            \"cost\": {\n              \"input\": 0,\n              \"output\": 0,\n              \"cacheRead\": 0,\n              \"cacheWrite\": 0\n            },\n            \"contextWindow\": 1000000,\n            \"maxTokens\": 8192\n          },\n          {\n            \"id\": \"qwen-turbo\",\n            \"name\": \"Qwen Turbo (PayGo)\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\"],\n            \"cost\": { \"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0 },\n            \"contextWindow\": 1000000,\n            \"maxTokens\": 8192\n          },\n          {\n            \"id\": \"qwen-vl-plus\",\n            \"name\": \"Qwen VL Plus (PayGo)\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\", \"image\"],\n            \"cost\": { \"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0 },\n            \"contextWindow\": 128000,\n            \"maxTokens\": 4096\n          }\n        ]\n      },\n\n      // ────────────────────────────────────────────────────────────\n      // 阿里云百炼 - 编程模型\n      // ────────────────────────────────────────────────────────────\n      \"dashscope-coding\": {\n        \"baseUrl\": \"https://coding.dashscope.aliyuncs.com/v1\",\n        \"apiKey\": \"${DASHSCOPE_CODING_API_KEY}\",\n        \"api\": \"openai-completions\",\n        \"models\": [\n          {\n            \"id\": \"qwen3.5-plus\",\n            \"name\": \"Qwen3.5 Plus (Coding Plan)\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\", \"image\"],\n            \"cost\": { \"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0 },\n            \"contextWindow\": 1000000,\n            \"maxTokens\": 65536\n          },\n          {\n            \"id\": \"qwen3-max-2026-01-23\",\n            \"name\": \"Qwen3 Max (Coding Plan)\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\"],\n            \"cost\": { \"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0 },\n            \"contextWindow\": 262144,\n            \"maxTokens\": 65536\n          },\n          {\n            \"id\": \"kimi-k2.5\",\n            \"name\": \"Kimi K2.5 (Coding Plan)\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\", \"image\"],\n            \"cost\": { \"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0 },\n            \"contextWindow\": 262144,\n            \"maxTokens\": 32768\n          },\n          {\n            \"id\": \"MiniMax-M2.5\",\n            \"name\": \"MiniMax M2.5 (Coding Plan)\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\"],\n            \"cost\": { \"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0 },\n            \"contextWindow\": 204800,\n            \"maxTokens\": 131072\n          }\n        ]\n      },\n\n      // ────────────────────────────────────────────────────────────\n      // Anthropic\n      // ────────────────────────────────────────────────────────────\n      \"anthropic\": {\n        \"baseUrl\": \"https://api.anthropic.com/v1\",\n        \"apiKey\": \"${ANTHROPIC_API_KEY}\",\n        \"api\": \"openai-completions\",\n        \"models\": [\n          {\n            \"id\": \"claude-opus-4-6\",\n            \"name\": \"Claude Opus 4.6\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": true,\n            \"input\": [\"text\", \"image\"],\n            \"cost\": { \"input\": 15, \"output\": 75, \"cacheRead\": 1.5, \"cacheWrite\": 18.75 },\n            \"contextWindow\": 200000,\n            \"maxTokens\": 64000\n          },\n          {\n            \"id\": \"claude-sonnet-4-6\",\n            \"name\": \"Claude Sonnet 4.6\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\", \"image\"],\n            \"cost\": { \"input\": 3, \"output\": 15, \"cacheRead\": 0.3, \"cacheWrite\": 3.75 },\n            \"contextWindow\": 200000,\n            \"maxTokens\": 64000\n          }\n        ]\n      },\n\n      // ────────────────────────────────────────────────────────────\n      // OpenAI\n      // ────────────────────────────────────────────────────────────\n      \"openai\": {\n        \"baseUrl\": \"https://api.openai.com/v1\",\n        \"apiKey\": \"${OPENAI_API_KEY}\",\n        \"api\": \"openai-completions\",\n        \"models\": [\n          {\n            \"id\": \"gpt-5.4\",\n            \"name\": \"GPT-5.4\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": true,\n            \"input\": [\"text\", \"image\"],\n            \"cost\": { \"input\": 2, \"output\": 8, \"cacheRead\": 0.2, \"cacheWrite\": 2.5 },\n            \"contextWindow\": 400000,\n            \"maxTokens\": 64000\n          },\n          {\n            \"id\": \"gpt-5-mini\",\n            \"name\": \"GPT-5 Mini\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\", \"image\"],\n            \"cost\": { \"input\": 0.25, \"output\": 1, \"cacheRead\": 0.025, \"cacheWrite\": 0.125 },\n            \"contextWindow\": 400000,\n            \"maxTokens\": 64000\n          }\n        ]\n      },\n\n      // ────────────────────────────────────────────────────────────\n      // Google (示例)\n      // ────────────────────────────────────────────────────────────\n      \"google\": {\n        \"baseUrl\": \"https://generativelanguage.googleapis.com/v1beta/openai\",\n        \"apiKey\": \"${GOOGLE_API_KEY}\",\n        \"api\": \"openai-completions\",\n        \"models\": [\n          {\n            \"id\": \"gemini-3.1-pro-preview\",\n            \"name\": \"Gemini 3.1 Pro\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\", \"image\"],\n            \"cost\": { \"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0 },\n            \"contextWindow\": 2000000,\n            \"maxTokens\": 65536\n          },\n          {\n            \"id\": \"gemini-3-flash-preview\",\n            \"name\": \"Gemini 3 Flash\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\", \"image\"],\n            \"cost\": { \"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0 },\n            \"contextWindow\": 1000000,\n            \"maxTokens\": 65536\n          }\n        ]\n      },\n\n      // ────────────────────────────────────────────────────────────\n      // 自定义/OpenAI 兼容\n      // ────────────────────────────────────────────────────────────\n      \"custom\": {\n        \"baseUrl\": \"https://your-api-server.com/v1\",\n        \"apiKey\": \"${CUSTOM_API_KEY}\",\n        \"api\": \"openai-completions\",\n        \"models\": [\n          {\n            \"id\": \"custom-model\",\n            \"name\": \"Custom Model\",\n            \"api\": \"openai-completions\",\n            \"reasoning\": false,\n            \"input\": [\"text\"],\n            \"cost\": { \"input\": 0, \"output\": 0, \"cacheRead\": 0, \"cacheWrite\": 0 },\n            \"contextWindow\": 128000,\n            \"maxTokens\": 8192\n          }\n        ]\n      }\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 5. Agent 配置 - 核心模块\n  // ═══════════════════════════════════════════════════════════════\n  \"agents\": {\n    \"defaults\": {\n      // ────────────────────────────────────────────────────────────\n      // 模型选择\n      // ────────────────────────────────────────────────────────────\n      \"model\": {\n        \"primary\": \"dashscope-coding/qwen3.5-plus\",\n        \"fallbacks\": [\n          \"dashscope-coding/kimi-k2.5\",\n          \"dashscope/qwen-plus\"\n        ]\n      },\n\n      \"models\": {\n        \"dashscope-coding/qwen3.5-plus\": { \"alias\": \"coding\" },\n        \"dashscope-coding/kimi-k2.5\": { \"alias\": \"kimi\" },\n        \"dashscope-coding/qwen3-max-2026-01-23\": { \"alias\": \"max\" },\n        \"dashscope-coding/MiniMax-M2.5\": { \"alias\": \"minimax\" },\n        \"dashscope/qwen-plus\": { \"alias\": \"plus-paygo\" },\n        \"dashscope/qwen-turbo\": { \"alias\": \"turbo\" },\n        \"dashscope/qwen-vl-plus\": { \"alias\": \"vl\" },\n        \"dashscope-image/qwen-image-2.0\": { \"alias\": \"draw\" },\n        \"dashscope-audio/qwen3-tts-flash\": { \"alias\": \"tts\" },\n        \"anthropic/claude-opus-4-6\": { \"alias\": \"opus\" },\n        \"anthropic/claude-sonnet-4-6\": { \"alias\": \"sonnet\" },\n        \"openai/gpt-5.4\": { \"alias\": \"gpt\" },\n        \"openai/gpt-5-mini\": { \"alias\": \"gpt-mini\" },\n        \"google/gemini-3.1-pro-preview\": { \"alias\": \"gemini\" },\n        \"google/gemini-3-flash-preview\": { \"alias\": \"gemini-flash\" }\n      },\n\n      // ────────────────────────────────────────────────────────────\n      // 工作空间\n      // ────────────────────────────────────────────────────────────\n      \"workspace\": \"C:\\\\Users\\\\28964\\\\.openclaw\\\\workspace\",\n      \"repoRoot\": \"~/Projects/openclaw\",\n      \"skipBootstrap\": false,\n      \"bootstrapMaxChars\": 20000,\n      \"bootstrapTotalMaxChars\": 150000,\n      \"bootstrapPromptTruncationWarning\": \"once\",\n\n      // ────────────────────────────────────────────────────────────\n      // 图像处理\n      // ────────────────────────────────────────────────────────────\n      \"imageMaxDimensionPx\": 1200,\n\n      // ────────────────────────────────────────────────────────────\n      // 时间配置\n      // ────────────────────────────────────────────────────────────\n      \"userTimezone\": \"Asia/Shanghai\",\n      \"timeFormat\": \"auto\",\n\n      // ────────────────────────────────────────────────────────────\n      // 模型参数\n      // ────────────────────────────────────────────────────────────\n      \"imageModel\": {\n        \"primary\": \"dashscope-image/qwen-image-2.0\",\n        \"fallbacks\": []\n      },\n      \"pdfModel\": {\n        \"primary\": \"dashscope-coding/qwen3.5-plus\",\n        \"fallbacks\": [\"dashscope/qwen-vl-plus\"]\n      },\n      \"pdfMaxBytesMb\": 10,\n      \"pdfMaxPages\": 20,\n      \"thinkingDefault\": \"low\",\n      \"verboseDefault\": \"off\",\n      \"elevatedDefault\": \"on\",\n      \"timeoutSeconds\": 600,\n      \"mediaMaxMb\": 5,\n      \"contextTokens\": 200000,\n      \"maxConcurrent\": 3,\n\n      // ────────────────────────────────────────────────────────────\n      // 心跳配置\n      // ────────────────────────────────────────────────────────────\n      \"heartbeat\": {\n        \"every\": \"30m\",\n        \"model\": \"dashscope-coding/qwen3.5-plus\",\n        \"includeReasoning\": false,\n        \"lightContext\": false,\n        \"session\": \"main\",\n        \"to\": \"+8613800138000\",\n        \"directPolicy\": \"allow\",\n        \"target\": \"none\",\n        \"prompt\": \"Read HEARTBEAT.md if it exists (workspace context). Follow it strictly. Do not infer or repeat old tasks from prior chats. If nothing needs attention, reply HEARTBEAT_OK.\",\n        \"ackMaxChars\": 300,\n        \"suppressToolErrorWarnings\": false\n      },\n\n      // ────────────────────────────────────────────────────────────\n      // 会话压缩\n      // ────────────────────────────────────────────────────────────\n      \"compaction\": {\n        \"mode\": \"safeguard\",\n        \"reserveTokensFloor\": 24000,\n        \"identifierPolicy\": \"strict\",\n        \"identifierInstructions\": \"Preserve deployment IDs, ticket IDs, and host:port pairs exactly.\",\n        \"postCompactionSections\": [\"Session Startup\", \"Red Lines\"],\n        \"model\": \"anthropic/claude-sonnet-4-6\",\n        \"memoryFlush\": {\n          \"enabled\": true,\n          \"softThresholdTokens\": 6000,\n          \"systemPrompt\": \"Session nearing compaction. Store durable memories now.\",\n          \"prompt\": \"Write any lasting notes to memory/YYYY-MM-DD.md; reply with NO_REPLY if nothing to store.\"\n        }\n      },\n\n      // ────────────────────────────────────────────────────────────\n      // 上下文修剪\n      // ────────────────────────────────────────────────────────────\n      \"contextPruning\": {\n        \"mode\": \"cache-ttl\",\n        \"ttl\": \"1h\",\n        \"keepLastAssistants\": 3,\n        \"softTrimRatio\": 0.3,\n        \"hardClearRatio\": 0.5,\n        \"minPrunableToolChars\": 50000,\n        \"softTrim\": { \"maxChars\": 4000, \"headChars\": 1500, \"tailChars\": 1500 },\n        \"hardClear\": {\n          \"enabled\": true,\n          \"placeholder\": \"[Old tool result content cleared]\"\n        },\n        \"tools\": { \"deny\": [\"browser\", \"canvas\"] }\n      },\n\n      // ────────────────────────────────────────────────────────────\n      // 块流式输出\n      // ────────────────────────────────────────────────────────────\n      \"blockStreamingDefault\": \"off\",\n      \"blockStreamingBreak\": \"text_end\",\n      \"blockStreamingChunk\": { \"minChars\": 800, \"maxChars\": 1200 },\n      \"blockStreamingCoalesce\": { \"idleMs\": 1000 },\n      \"humanDelay\": {\n        \"mode\": \"natural\",\n        \"minMs\": 800,\n        \"maxMs\": 2500\n      },\n\n      // ────────────────────────────────────────────────────────────\n      // 打字指示器\n      // ────────────────────────────────────────────────────────────\n      \"typingMode\": \"instant\",\n      \"typingIntervalSeconds\": 6,\n\n      // ────────────────────────────────────────────────────────────\n      // CLI 后端\n      // ────────────────────────────────────────────────────────────\n      \"cliBackends\": {\n        // \"claude-cli\": {\n        //   \"command\": \"/opt/homebrew/bin/claude\",\n        //   \"args\": [\"--json\"],\n        //   \"modelArg\": \"--model\",\n        //   \"sessionArg\": \"--session\",\n        //   \"sessionMode\": \"existing\"\n        // }\n      },\n\n      // ────────────────────────────────────────────────────────────\n      // Docker 沙箱\n      // ────────────────────────────────────────────────────────────\n      \"sandbox\": {\n        \"mode\": \"non-main\",\n        \"scope\": \"agent\",\n        \"workspaceAccess\": \"none\",\n        \"workspaceRoot\": \"~/.openclaw/sandboxes\",\n        \"docker\": {\n          \"image\": \"openclaw-sandbox:bookworm-slim\",\n          \"containerPrefix\": \"openclaw-sbx-\",\n          \"workdir\": \"/workspace\",\n          \"readOnlyRoot\": true,\n          \"tmpfs\": [\"/tmp\", \"/var/tmp\", \"/run\"],\n          \"network\": \"none\",\n          \"user\": \"1000:1000\",\n          \"capDrop\": [\"ALL\"],\n          \"env\": { \"LANG\": \"C.UTF-8\" },\n          \"setupCommand\": \"apt-get update && apt-get install -y git curl jq\",\n          \"pidsLimit\": 256,\n          \"memory\": \"1g\",\n          \"memorySwap\": \"2g\",\n          \"cpus\": 1,\n          \"ulimits\": {\n            \"nofile\": { \"soft\": 1024, \"hard\": 2048 },\n            \"nproc\": 256\n          },\n          \"dns\": [\"1.1.1.1\", \"8.8.8.8\"]\n        },\n        \"browser\": {\n          \"enabled\": false,\n          \"image\": \"openclaw-sandbox-browser:bookworm-slim\",\n          \"network\": \"openclaw-sandbox-browser\",\n          \"cdpPort\": 9222,\n          \"cdpSourceRange\": \"172.21.0.1/32\",\n          \"vncPort\": 5900,\n          \"noVncPort\": 6080,\n          \"headless\": false,\n          \"enableNoVnc\": true,\n          \"allowHostControl\": false,\n          \"autoStart\": true,\n          \"autoStartTimeoutMs\": 12000\n        },\n        \"prune\": {\n          \"idleHours\": 24,\n          \"maxAgeDays\": 7\n        }\n      }\n    },\n\n    // ────────────────────────────────────────────────────────────\n    // 多 Agent 配置\n    // ────────────────────────────────────────────────────────────\n    \"list\": [\n      {\n        \"id\": \"main\",\n        \"default\": true,\n        \"name\": \"Main Agent\",\n        \"workspace\": \"C:\\\\Users\\\\28964\\\\.openclaw\\\\workspace\",\n        \"model\": {\n          \"primary\": \"dashscope-coding/qwen3.5-plus\",\n          \"fallbacks\": [\"dashscope-coding/kimi-k2.5\"]\n        },\n        \"identity\": {\n          \"name\": \"Samantha\",\n          \"theme\": \"helpful assistant\",\n          \"emoji\": \"🦥\",\n          \"avatar\": \"avatars/samantha.png\",\n          \"ackReaction\": \"👀\"\n        },\n        \"groupChat\": {\n          \"mentionPatterns\": [\"@openclaw\", \"@助手\"]\n        },\n        \"params\": {\n          \"cacheRetention\": \"none\",\n          \"temperature\": 0.7\n        },\n        \"subagents\": {\n          \"allowAgents\": [\"*\"]\n        }\n      }\n    ],\n\n    // ────────────────────────────────────────────────────────────\n    // Agent 路由绑定\n    // ────────────────────────────────────────────────────────────\n    \"bindings\": [\n      // {\n      //   \"agentId\": \"main\",\n      //   \"match\": {\n      //     \"channel\": \"whatsapp\",\n      //     \"accountId\": \"personal\"\n      //   }\n      // }\n    ]\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 6. 会话管理\n  // ═══════════════════════════════════════════════════════════════\n  \"session\": {\n    \"dmScope\": \"per-channel-peer\",\n    \"identityLinks\": {\n      // \"alice\": [\"telegram:123456789\", \"discord:987654321012345678\"]\n    },\n    \"reset\": {\n      \"mode\": \"daily\",\n      \"atHour\": 4,\n      \"idleMinutes\": 120\n    },\n    \"resetByType\": {\n      \"thread\": { \"mode\": \"daily\", \"atHour\": 4 },\n      \"direct\": { \"mode\": \"idle\", \"idleMinutes\": 240 },\n      \"group\": { \"mode\": \"idle\", \"idleMinutes\": 120 }\n    },\n    \"resetTriggers\": [\"/new\", \"/reset\"],\n    \"store\": \"~/.openclaw/agents/{agentId}/sessions/sessions.json\",\n    \"parentForkMaxTokens\": 100000,\n    \"maintenance\": {\n      \"mode\": \"warn\",\n      \"pruneAfter\": \"30d\",\n      \"maxEntries\": 500,\n      \"rotateBytes\": \"10mb\",\n      \"resetArchiveRetention\": \"30d\",\n      \"maxDiskBytes\": \"500mb\",\n      \"highWaterBytes\": \"400mb\"\n    },\n    \"threadBindings\": {\n      \"enabled\": true,\n      \"idleHours\": 24,\n      \"maxAgeHours\": 0\n    },\n    \"mainKey\": \"main\",\n    \"agentToAgent\": {\n      \"maxPingPongTurns\": 5\n    },\n    \"sendPolicy\": {\n      \"rules\": [\n        // {\n        //   \"action\": \"deny\",\n        //   \"match\": { \"channel\": \"discord\", \"chatType\": \"group\" }\n        // }\n      ]\n    },\n    \"typingMode\": \"instant\",\n    \"typingIntervalSeconds\": 6\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 7. 消息配置 - 核心模块\n  // ═══════════════════════════════════════════════════════════════\n  \"messages\": {\n    // 响应前缀\n    \"responsePrefix\": \"🦞\",\n    // 确认反应\n    \"ackReaction\": \"👀\",\n    \"ackReactionScope\": \"group-mentions\",\n    \"removeAckAfterReply\": false,\n\n    // 群组聊天\n    \"groupChat\": {\n      \"historyLimit\": 50,\n      \"mentionPatterns\": [\"@openclaw\", \"@助手\"]\n    },\n\n    // 消息队列\n    \"queue\": {\n      \"mode\": \"collect\",\n      \"debounceMs\": 1000,\n      \"cap\": 20,\n      \"drop\": \"summarize\",\n      \"byChannel\": {\n        \"whatsapp\": \"collect\",\n        \"telegram\": \"collect\",\n        \"discord\": \"steer\"\n      }\n    },\n\n    // 入站防抖\n    \"inbound\": {\n      \"debounceMs\": 2000,\n      \"byChannel\": {\n        \"whatsapp\": 5000,\n        \"slack\": 1500,\n        \"telegram\": 3000\n      }\n    },\n\n    // TTS 语音合成\n    \"tts\": {\n      \"auto\": \"always\",\n      \"mode\": \"final\",\n      \"provider\": \"elevenlabs\",\n      \"summaryModel\": \"openai/gpt-4.1-mini\",\n      \"modelOverrides\": { \"enabled\": true, \"allowProvider\": false },\n      \"maxTextLength\": 4000,\n      \"timeoutMs\": 30000,\n      \"prefsPath\": \"~/.openclaw/settings/tts.json\",\n      \"elevenlabs\": {\n        \"apiKey\": \"${ELEVENLABS_API_KEY}\",\n        \"baseUrl\": \"https://api.elevenlabs.io\",\n        \"voiceId\": \"EXAVITQu4vr4xnSDxMaL\",\n        \"modelId\": \"eleven_multilingual_v2\",\n        \"seed\": 42,\n        \"applyTextNormalization\": \"auto\",\n        \"languageCode\": \"zh\",\n        \"voiceSettings\": {\n          \"stability\": 0.5,\n          \"similarityBoost\": 0.75,\n          \"style\": 0.0,\n          \"useSpeakerBoost\": true,\n          \"speed\": 1.0\n        }\n      },\n      \"openai\": {\n        \"apiKey\": \"${OPENAI_API_KEY}\",\n        \"baseUrl\": \"https://api.openai.com/v1\",\n        \"model\": \"gpt-4o-mini-tts\",\n        \"voice\": \"alloy\"\n      }\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 8. 工具配置\n  // ═══════════════════════════════════════════════════════════════\n  \"tools\": {\n    \"profile\": \"coding\",\n    \"allow\": [\n      \"browser\",\n      \"canvas\"\n    ],\n    \"deny\": [\n      \"nodes.camera.snap\",\n      \"nodes.screen.record\"\n    ],\n    \"elevated\": {\n      \"enabled\": true,\n      \"mode\": \"dangerous\",\n      \"allowlist\": [\"git\", \"npm\", \"pnpm\", \"yarn\"],\n      \"allowFrom\": {\n        \"whatsapp\": [\"+8613800138000\"],\n        \"telegram\": [\"tg:123456789\"]\n      }\n    },\n    \"web\": {\n      \"search\": {\n        \"provider\": \"brave\",\n        \"apiKey\": \"${BRAVE_API_KEY}\"\n      }\n    },\n    \"browser\": {\n      \"enabled\": true,\n      \"color\": \"#FF4500\",\n      \"headless\": false,\n      \"profile\": \"default\",\n      \"args\": [\"--no-sandbox\", \"--disable-dev-shm-usage\"],\n      \"remoteDebuggingPort\": 9222,\n      \"userDataDir\": \"~/.openclaw/browser-profiles/default\"\n    },\n    \"bash\": {\n      \"enabled\": true,\n      \"requireApproval\": \"dangerous\"\n    },\n    \"sandbox\": {\n      \"tools\": {\n        \"allow\": [\n          \"exec\", \"process\", \"read\", \"write\", \"edit\",\n          \"sessions_list\", \"sessions_history\", \"sessions_send\"\n        ],\n        \"deny\": [\"browser\", \"canvas\", \"nodes\", \"cron\"]\n      }\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 9. 命令配置\n  // ═══════════════════════════════════════════════════════════════\n  \"commands\": {\n    \"native\": \"auto\",\n    \"text\": true,\n    \"bash\": false,\n    \"bashForegroundMs\": 2000,\n    \"config\": false,\n    \"debug\": false,\n    \"restart\": true,\n    \"allowFrom\": {\n      \"*\": [\"user1\", \"user2\"]\n    },\n    \"useAccessGroups\": true\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 10. 内部钩子\n  // ═══════════════════════════════════════════════════════════════\n  \"hooks\": {\n    \"internal\": {\n      \"enabled\": true,\n      \"entries\": {\n        \"bootstrap-extra-files\": { \"enabled\": true },\n        \"command-logger\": { \"enabled\": true },\n        \"session-memory\": { \"enabled\": true },\n        \"boot-md\": { \"enabled\": true }\n      }\n    },\n\n    // Gmail Pub/Sub\n    \"gmail\": {\n      \"enabled\": false,\n      \"projectId\": \"your-gcp-project\",\n      \"topicName\": \"gmail-projects\",\n      \"subscriptionName\": \"openclaw-gmail-sub\",\n      \"serviceAccountFile\": \"/path/to/service-account.json\",\n      \"pollInterval\": \"1m\",\n      \"maxMessages\": 10,\n      \"ackDeadline\": 300,\n      \"model\": \"dashscope-coding/qwen3.5-plus\",\n      \"allowUnsafeExternalContent\": false\n    },\n\n    // 外部 Webhook\n    \"external\": {\n      \"enabled\": true,\n      \"token\": \"${WEBHOOK_TOKEN}\",\n      \"path\": \"/hooks\",\n      \"defaultSessionKey\": \"hook:ingress\",\n      \"allowRequestSessionKey\": false,\n      \"allowedSessionKeyPrefixes\": [\"hook:\"],\n      \"mappings\": [\n        {\n          \"match\": { \"path\": \"gmail\" },\n          \"action\": \"agent\",\n          \"agentId\": \"main\",\n          \"deliver\": true\n        }\n      ]\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 11. 网关配置 - 核心模块\n  // ═══════════════════════════════════════════════════════════════\n  \"gateway\": {\n    \"port\": 18789,\n    \"mode\": \"local\",\n    \"bind\": \"loopback\",\n    \"auth\": {\n      \"mode\": \"token\",\n      \"token\": \"${OPENCLAW_GATEWAY_TOKEN}\",\n      \"allowTailscale\": true\n    },\n    \"reload\": {\n      \"mode\": \"hybrid\",\n      \"debounceMs\": 300\n    },\n    \"tailscale\": {\n      \"mode\": \"off\",\n      \"resetOnExit\": false\n    },\n    \"tls\": {\n      \"enabled\": false,\n      \"cert\": \"/path/to/cert.pem\",\n      \"key\": \"/path/to/key.pem\"\n    },\n    \"nodes\": {\n      \"denyCommands\": [\n        \"camera.snap\",\n        \"camera.clip\",\n        \"screen.record\",\n        \"contacts.add\",\n        \"calendar.add\",\n        \"reminders.add\",\n        \"sms.send\"\n      ]\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 12. 技能配置\n  // ═══════════════════════════════════════════════════════════════\n  \"skills\": {\n    \"entries\": {\n      \"search\": { \"enabled\": true },\n      \"browser\": { \"enabled\": true },\n      \"sag\": { \"enabled\": false }\n    },\n    \"load\": {\n      \"watch\": true,\n      \"watchDebounceMs\": 250,\n      \"extraDirs\": [\"~/.openclaw/shared-skills\"]\n    },\n    \"allowBundled\": [\"search\", \"browser\", \"docs\"]\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 13. Cron 自动化\n  // ═══════════════════════════════════════════════════════════════\n  \"cron\": {\n    \"enabled\": true,\n    \"store\": \"~/.openclaw/cron/jobs.json\",\n    \"maxConcurrentRuns\": 2,\n    \"sessionRetention\": \"24h\",\n    \"runLog\": {\n      \"maxBytes\": \"2mb\",\n      \"keepLines\": 2000\n    },\n    \"retry\": {\n      \"maxAttempts\": 3,\n      \"backoffMs\": [60000, 120000, 300000],\n      \"retryOn\": [\"rate_limit\", \"overloaded\", \"network\", \"server_error\"]\n    },\n    \"webhookToken\": \"${WEBHOOK_TOKEN}\"\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 14. 插件配置\n  // ═══════════════════════════════════════════════════════════════\n  \"plugins\": {\n    \"entries\": {\n      \"qwen-portal-auth\": { \"enabled\": true },\n      \"mattermost\": { \"enabled\": false },\n      \"voice-call\": { \"enabled\": false }\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 15. 渠道配置 - 核心模块\n  // ═══════════════════════════════════════════════════════════════\n  \"channels\": {\n    // 渠道默认配置\n    \"defaults\": {\n      \"groupPolicy\": \"allowlist\",\n      \"heartbeat\": {\n        \"showOk\": false,\n        \"showAlerts\": true,\n        \"useIndicator\": true\n      }\n    },\n\n    // 渠道模型覆盖\n    \"modelByChannel\": {\n      \"discord\": {\n        \"123456789012345678\": \"anthropic/claude-opus-4-6\"\n      },\n      \"telegram\": {\n        \"-1001234567890\": \"openai/gpt-4.1-mini\"\n      }\n    },\n\n    // WhatsApp\n    \"whatsapp\": {\n      \"dmPolicy\": \"pairing\",\n      \"allowFrom\": [\"+8613800138000\"],\n      \"textChunkLimit\": 4000,\n      \"chunkMode\": \"length\",\n      \"mediaMaxMb\": 50,\n      \"sendReadReceipts\": true,\n      \"groups\": { \"*\": { \"requireMention\": true } },\n      \"groupPolicy\": \"allowlist\",\n      \"groupAllowFrom\": [\"+8613800138000\"],\n      \"accounts\": {\n        \"default\": {},\n        \"personal\": {},\n        \"biz\": {}\n      }\n    },\n\n    // Telegram\n    \"telegram\": {\n      \"enabled\": true,\n      \"botToken\": \"${TELEGRAM_BOT_TOKEN}\",\n      \"dmPolicy\": \"pairing\",\n      \"allowFrom\": [\"tg:123456789\"],\n      \"groups\": {\n        \"*\": { \"requireMention\": true },\n        \"-1001234567890\": {\n          \"allowFrom\": [\"@admin\"],\n          \"topics\": {\n            \"99\": {\n              \"requireMention\": false,\n              \"systemPrompt\": \"保持话题相关\"\n            }\n          }\n        }\n      },\n      \"customCommands\": [\n        { \"command\": \"backup\", \"description\": \"Git 备份\" }\n      ],\n      \"historyLimit\": 50,\n      \"replyToMode\": \"first\",\n      \"linkPreview\": true,\n      \"streaming\": \"partial\",\n      \"mediaMaxMb\": 100,\n      \"webhookUrl\": \"https://example.com/telegram-webhook\",\n      \"webhookSecret\": \"${TELEGRAM_WEBHOOK_SECRET}\"\n    },\n\n    // Discord\n    \"discord\": {\n      \"enabled\": true,\n      \"token\": \"${DISCORD_BOT_TOKEN}\",\n      \"mediaMaxMb\": 8,\n      \"allowBots\": false,\n      \"dmPolicy\": \"pairing\",\n      \"allowFrom\": [\"1234567890\"],\n      \"guilds\": {\n        \"123456789012345678\": {\n          \"slug\": \"my-server\",\n          \"requireMention\": false,\n          \"channels\": {\n            \"general\": { \"allow\": true },\n            \"help\": {\n              \"allow\": true,\n              \"requireMention\": true,\n              \"systemPrompt\": \"简短回答\"\n            }\n          }\n        }\n      },\n      \"voice\": {\n        \"enabled\": true,\n        \"autoJoin\": [{\n          \"guildId\": \"123456789012345678\",\n          \"channelId\": \"234567890123456789\"\n        }],\n        \"tts\": {\n          \"provider\": \"openai\",\n          \"openai\": { \"voice\": \"alloy\" }\n        }\n      },\n      \"threadBindings\": {\n        \"enabled\": true,\n        \"idleHours\": 24,\n        \"maxAgeHours\": 0\n      }\n    },\n\n    // Slack\n    \"slack\": {\n      \"enabled\": true,\n      \"botToken\": \"${SLACK_BOT_TOKEN}\",\n      \"appToken\": \"${SLACK_APP_TOKEN}\",\n      \"dmPolicy\": \"pairing\",\n      \"allowFrom\": [\"U123\", \"U456\"],\n      \"channels\": {\n        \"C123\": { \"allow\": true, \"requireMention\": true }\n      },\n      \"slashCommand\": {\n        \"enabled\": true,\n        \"name\": \"openclaw\",\n        \"ephemeral\": true\n      }\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 16. Talk 模式配置\n  // ═══════════════════════════════════════════════════════════════\n  \"talk\": {\n    \"voiceId\": \"EXAVITQu4vr4xnSDxMaL\",\n    \"voiceAliases\": {\n      \"Clawd\": \"EXAVITQu4vr4xnSDxMaL\",\n      \"Roger\": \"CwhRBWXzGAHq8TQ4Fs17\",\n      \"Samantha\": \"your-voice-id\"\n    },\n    \"modelId\": \"eleven_v3\",\n    \"outputFormat\": \"mp3_44100_128\",\n    \"apiKey\": \"${ELEVENLABS_API_KEY}\",\n    \"silenceTimeoutMs\": 1500,\n    \"interruptOnSpeech\": true\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 17. 浏览器配置\n  // ═══════════════════════════════════════════════════════════════\n  \"browser\": {\n    \"enabled\": true,\n    \"color\": \"#FF4500\",\n    \"headless\": false,\n    \"profile\": \"default\",\n    \"args\": [\"--no-sandbox\", \"--disable-dev-shm-usage\"],\n    \"remoteDebuggingPort\": 9222,\n    \"userDataDir\": \"~/.openclaw/browser-profiles/default\"\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 18. 日志配置\n  // ═══════════════════════════════════════════════════════════════\n  \"logging\": {\n    \"level\": \"info\",\n    \"format\": \"json\",\n    \"file\": \"~/.openclaw/logs/openclaw.log\",\n    \"console\": true,\n    \"rotation\": {\n      \"maxSize\": \"10mb\",\n      \"maxFiles\": 5\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 19. 身份配置\n  // ═══════════════════════════════════════════════════════════════\n  \"identity\": {\n    \"name\": \"Samantha\",\n    \"theme\": \"helpful assistant\",\n    \"emoji\": \"🦥\",\n    \"avatar\": \"avatars/samantha.png\",\n    \"ackReaction\": \"👀\"\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 20. 发现配置\n  // ═══════════════════════════════════════════════════════════════\n  \"discovery\": {\n    \"enabled\": true,\n    \"broadcastInterval\": 30,\n    \"serviceType\": \"_openclaw._tcp\",\n    \"serviceName\": \"OpenClaw Gateway\"\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 21. Canvas 主机配置\n  // ═══════════════════════════════════════════════════════════════\n  \"canvasHost\": {\n    \"enabled\": true,\n    \"path\": \"/__openclaw__/canvas/\",\n    \"a2uiPath\": \"/__openclaw__/a2ui/\",\n    \"allowedOrigins\": [\"*\"]\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 22. 音频配置\n  // ═══════════════════════════════════════════════════════════════\n  \"audio\": {\n    \"inputDevice\": \"default\",\n    \"outputDevice\": \"default\",\n    \"sampleRate\": 44100,\n    \"channels\": 2,\n    \"bufferSize\": 2048\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 23. 审批配置\n  // ═══════════════════════════════════════════════════════════════\n  \"approvals\": {\n    \"exec\": {\n      \"mode\": \"dangerous\",\n      \"allowlist\": [\"git\", \"npm\", \"pnpm\", \"yarn\", \"docker\"],\n      \"dangerousPatterns\": [\"rm\", \"del\", \"format\", \"mkfs\"],\n      \"timeoutSeconds\": 300\n    },\n    \"network\": {\n      \"mode\": \"allowlist\",\n      \"allowlist\": [\"api.openai.com\", \"api.anthropic.com\"]\n    },\n    \"write\": {\n      \"mode\": \"dangerous\",\n      \"allowlist\": [\"*.md\", \"*.txt\", \"*.json\"],\n      \"denyPatterns\": [\"*.exe\", \"*.dll\", \"*.sh\"]\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 24. 备份配置\n  // ═══════════════════════════════════════════════════════════════\n  \"backup\": {\n    \"enabled\": true,\n    \"interval\": \"24h\",\n    \"destination\": \"~/.openclaw/backups\",\n    \"retention\": 7,\n    \"compress\": true,\n    \"encrypt\": false\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 25. 性能配置\n  // ═══════════════════════════════════════════════════════════════\n  \"performance\": {\n    \"maxMemory\": 2048,\n    \"maxCpu\": 80,\n    \"gcInterval\": 300,\n    \"cacheSize\": 512\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 26. 监控配置\n  // ═══════════════════════════════════════════════════════════════\n  \"monitoring\": {\n    \"enabled\": true,\n    \"healthCheckInterval\": 60,\n    \"metrics\": {\n      \"enabled\": true,\n      \"port\": 9090,\n      \"path\": \"/metrics\"\n    },\n    \"alerts\": {\n      \"enabled\": false,\n      \"webhook\": \"https://hooks.slack.com/xxx\",\n      \"thresholds\": {\n        \"memory\": 90,\n        \"cpu\": 80,\n        \"errorRate\": 5\n      }\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 27. OAuth 配置\n  // ═══════════════════════════════════════════════════════════════\n  \"oauth\": {\n    \"providers\": {\n      \"google\": {\n        \"clientId\": \"${GOOGLE_CLIENT_ID}\",\n        \"clientSecret\": \"${GOOGLE_CLIENT_SECRET}\",\n        \"redirectUri\": \"http://localhost:18789/oauth/callback\",\n        \"scopes\": [\"gmail.readonly\", \"calendar.readonly\"]\n      },\n      \"github\": {\n        \"clientId\": \"${GITHUB_CLIENT_ID}\",\n        \"clientSecret\": \"${GITHUB_CLIENT_SECRET}\",\n        \"redirectUri\": \"http://localhost:18789/oauth/callback\",\n        \"scopes\": [\"repo\", \"user\"]\n      }\n    }\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 28. 广播群组配置\n  // ═══════════════════════════════════════════════════════════════\n  \"broadcast\": {\n    \"groups\": [\n      {\n        \"id\": \"alerts\",\n        \"name\": \"Alert Broadcast\",\n        \"channels\": [\n          {\n            \"provider\": \"whatsapp\",\n            \"target\": \"+8613800138000\"\n          },\n          {\n            \"provider\": \"telegram\",\n            \"target\": \"tg:123456789\"\n          }\n        ]\n      }\n    ]\n  },\n\n  // ═══════════════════════════════════════════════════════════════\n  // 29. 位置服务配置\n  // ═══════════════════════════════════════════════════════════════\n  \"location\": {\n    \"enabled\": true,\n    \"provider\": \"system\",\n    \"updateInterval\": \"5m\",\n    \"accuracy\": \"high\",\n    \"cache\": {\n      \"enabled\": true,\n      \"ttl\": \"10m\"\n    }\n  }\n}\n"}}],"api":"openai-completions","p
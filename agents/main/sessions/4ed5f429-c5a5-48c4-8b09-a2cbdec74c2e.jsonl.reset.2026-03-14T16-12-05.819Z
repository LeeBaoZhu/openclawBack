ing\",\n    \"allow\": [\n      \"browser\",\n      \"read\",\n      \"write\",\n      \"edit\",\n      \"exec\",\n      \"process\",\n      \"sessions_list\",\n      \"sessions_history\",\n      \"sessions_send\",\n      \"sessions_spawn\",\n      \"session_status\",\n      \"subagents\",\n      \"cron\",\n      \"gateway\",\n      \"image\",\n      \"canvas\",\n      \"memory_search\",\n      \"memory_get\",\n      \"web_search\",\n      \"web_fetch\",\n      \"message\"\n    ],\n    \"deny\": [\n      \"nodes.camera.snap\",\n      \"nodes.screen.record\",\n      \"bash\",\n      \"nodes.camera.stream\",\n      \"nodes.mic.record\",\n      \"nodes.speaker.play\"\n    ],\n    \"web\": {\n      \"search\": {\n        \"enabled\": true,\n        \"provider\": \"brave\",\n        \"apiKey\": \"BSAAg5L5kNDIJY9C0R4JrJcuKyRjfdo\",\n        \"maxResults\": 5,\n        \"timeoutSeconds\": 30\n      },\n      \"fetch\": {\n        \"enabled\": true,\n        \"maxChars\": 50000,\n        \"timeoutSeconds\": 30,\n        \"userAgent\": \"OpenClaw/1.0\"\n      }\n    },\n    \"agentToAgent\": {\n      \"enabled\": true,\n      \"allow\": [\n        \"*\"\n      ]\n    },\n    \"elevated\": {\n      \"enabled\": true\n    }\n  },\n  \"broadcast\": {},\n  \"audio\": {},\n  \"messages\": {\n    \"responsePrefix\": \"🦞\",\n    \"groupChat\": {\n      \"mentionPatterns\": [\n        \"@openclaw\",\n        \"@助手\"\n      ],\n      \"historyLimit\": 50\n    },\n    \"queue\": {\n      \"mode\": \"collect\",\n      \"byChannel\": {\n        \"whatsapp\": \"collect\",\n        \"telegram\": \"collect\",\n        \"discord\": \"steer\"\n      },\n      \"debounceMs\": 1000,\n      \"cap\": 20,\n      \"drop\": \"summarize\"\n    },\n    \"inbound\": {\n      \"debounceMs\": 2000,\n      \"byChannel\": {\n        \"whatsapp\": 5000,\n        \"slack\": 1500,\n        \"telegram\": 3000\n      }\n    },\n    \"ackReaction\": \"👀\",\n    \"removeAckAfterReply\": true\n  },\n  \"commands\
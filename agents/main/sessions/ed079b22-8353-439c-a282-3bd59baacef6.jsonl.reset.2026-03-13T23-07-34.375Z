{"type":"message","id":"ac99835a","parentId":"6a1505d8","timestamp":"2026-03-13T00:50:04.085Z","message":{"role":"toolResult","toolCallId":"call_dc521bd760b74e3987cc1809","toolName":"read","content":[{"type":"text","text":"{\n  \"status\": \"error\",\n  \"tool\": \"read\",\n  \"error\": \"ENOENT: no such file or directory, access 'F:\\\\Program\\\\nvm\\\\node_global\\\\node_modules\\\\openclaw\\\\docs\\\\tools\\\\sessions_send.md'\"\n}"}],"details":{"status":"error","tool":"read","error":"ENOENT: no such file or directory, access 'F:\\Program\\nvm\\node_global\\node_modules\\openclaw\\docs\\tools\\sessions_send.md'"},"isError":false,"timestamp":1773363004078}}

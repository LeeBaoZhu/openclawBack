{"type":"message","id":"2ea830fc","parentId":"0b16f438","timestamp":"2026-03-14T16:20:16.324Z","message":{"role":"toolResult","toolCallId":"function.read:29","toolName":"read","content":[{"type":"text","text":"{\n  \"name\": \"openclaw-tavily\",\n  \"version\": \"0.2.1\",\n  \"type\": \"module\",\n  \"description\": \"Tavily web tools plugin for OpenClaw — exposes tavily_search, tavily_extract, tavily_crawl, tavily_map, and tavily_research as agent tools\",\n  \"license\": \"MIT\",\n  \"author\": \"Framix (https://framix.net)\",\n  \"repository\": {\n    \"type\": \"git\",\n    \"url\": \"https://github.com/framix-team/openclaw-tavily.git\"\n  },\n  \"homepage\": \"https://github.com/framix-team/openclaw-tavily#readme\",\n  \"bugs\": {\n    \"url\": \"https://github.com/framix-team/openclaw-tavily/issues\"\n  },\n  \"keywords\": [\n    \"openclaw\",\n    \"openclaw-plugin\",\n    \"tavily\",\n    \"search\",\n    \"web-search\",\n    \"ai-search\"\n  ],\n  \"files\": [\n    \"index.ts\",\n    \"openclaw.plugin.json\",\n    \"skills\",\n    \"README.md\",\n    \"LICENSE\"\n  ],\n  \"dependencies\": {\n    \"@sinclair/typebox\": \"0.34.47\"\n  },\n  \"peerDependencies\": {\n    \"openclaw\": \">=2025.0.0\"\n  },\n  \"peerDependenciesMeta\": {\n    \"openclaw\": {\n      \"optional\": true\n    }\n  },\n  \"openclaw\": {\n    \"extensions\": [\n      \"./index.ts\"\n    ]\n  }\n}\n"}],"isError":false,"timestamp":1773505216320}}
{"type":"message","id":"dc678865","parentId":"2ea830fc","timestamp":"2026-03-14T16:20:18.446Z","message":{"role":"assistant","content":[{"type":"text","text":"Good! I found the openclaw-tavily extension. Now let me check its plugin configuration file:\n\n"},{"type":"toolCall","id":"function.read:30","name":"read","arguments":{"path":"C:\\Users\\28964\\.openclaw\\extensions\\openclaw-tavily\\openclaw.plugin.json"}}],"api":"openai-completions","provider":"dashscope-coding","model":"kimi-k2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773505216326}}
{"type":"message","id":"118c61bc","parentId":"dc678865","timestamp":"2026-03-14T16:20:18.458Z","message":{"role":"toolResult","toolCallId":"function.read:30","toolName":"read","content":[{"type":"text","text":"{\n  \"id\": \"openclaw-tavily\",\n  \"kind\": \"tools\",\n  \"skills\": [\"./skills\"],\n  \"name\": \"Tavily Search\",\n  \"description\": \"Web tools via Tavily API. Provides tavily_search, tavily_extract, tavily_crawl, tavily_map, and tavily_research tools for search, content extraction, website crawling, site mapping, and deep research.\",\n  \"version\": \"0.2.0\",\n  \"configSchema\": {\n    \"type\": \"object\",\n    \"additionalProperties\": false,\n    \"properties\": {\n      \"apiKey\": {\n        \"type\": \"string\",\n        \"description\": \"Tavily API key (defaults to TAVILY_API_KEY env var)\"\n      },\n      \"searchDepth\": {\n        \"type\": \"string\",\n        \"enum\": [\"ultra-fast\", \"fast\", \"basic\", \"advanced\"],\n        \"description\": \"Search depth: ultra-fast, fast, basic, or advanced (thorough). Default: advanced\"\n      },\n      \"maxResults\": {\n        \"type\": \"number\",\n        \"description\": \"Default number of results (1-20). Default: 5\"\n      },\n      \"includeAnswer\": {\n        \"oneOf\": [\n          { \"type\": \"boolean\" },\n          { \"type\": \"string\", \"enum\": [\"basic\", \"advanced\"] }\n        ],\n        \"description\": \"Include an AI-generated short answer. Boolean or 'basic'/'advanced'. Default: true\"\n      },\n      \"includeRawContent\": {\n        \"oneOf\": [\n          { \"type\": \"boolean\" },\n          { \"type\": \"string\", \"enum\": [\"markdown\", \"text\"] }\n        ],\n        \"description\": \"Include raw page content. Boolean or 'markdown'/'text'. Default: false\"\n      },\n      \"timeoutSeconds\": {\n        \"type\": \"number\",\n        \"description\": \"Timeout in seconds for search requests. Default: 30\"\n      },\n      \"cacheTtlMinutes\": {\n        \"type\": \"number\",\n        \"description\": \"Cache TTL in minutes. Default: 15\"\n      }\n    }\n  },\n  \"uiHints\": {\n    \"apiKey\": {\n      \"label\": \"Tavily API Key\",\n      \"sensitive\": true,\n      \"placeholder\": \"tvly-...\"\n    },\n    \"searchDepth\": {\n      \"label\": \"Search Depth\",\n      \"help\": \"ultra-fast and fast are cheapest; advanced is slowest but most thorough.\"\n    },\n    \"maxResults\": {\n      \"label\": \"Max Results\",\n      \"help\": \"Number of results per search (1-20).\"\n    },\n    \"includeAnswer\": {\n      \"label\": \"Include AI Answer\",\n      \"help\": \"true/false, or 'basic'/'advanced' for answer quality tier.\"\n    },\n    \"includeRawContent\": {\n      \"label\": \"Include Raw Content\",\n      \"help\": \"true/false, or 'markdown'/'text' for format. Increases token usage.\",\n      \"advanced\": true\n    },\n    \"timeoutSeconds\": {\n      \"label\": \"Timeout (seconds)\",\n      \"advanced\": true\n    },\n    \"cacheTtlMinutes\": {\n      \"label\": \"Cache TTL (minutes)\",\n      \"help\": \"How long to cache results. Set 0 to disable.\",\n      \"advanced\": true\n    }\n  }\n}\n"}],"isError":false,"timestamp":1773505218455}}
